APP_NAME="Visitor Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (PostgreSQL — primary datastore, see CLAUDE.md) ---
# Host "postgres" is the docker-compose service name. Use 127.0.0.1 for host-side tooling.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=visitor_management
DB_USERNAME=vms
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Queues & cache (Redis — off-session notification jobs run on the queue) ---
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=local

# --- Broadcasting (Laravel Reverb — real-time guard tablet) ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=vms-local
REVERB_APP_KEY=vms-local-key
REVERB_APP_SECRET=vms-local-secret
# "reverb" is the docker service name; use localhost for host-side clients.
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
# Values the browser/tablet client uses to connect (exposed via Vite).
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8081
VITE_REVERB_SCHEME=http

# --- Africa's Talking (USSD aggregator + SMS provider) ---
# Sandbox credentials go here for dev; production keys are injected by the
# deployment environment. The sandbox MUST NOT hold real visitor data.
# AT_DRIVER selects the SMS gateway implementation: "log" (default, no network),
# or "africastalking" (real API) once Steven provides sandbox access.
AT_DRIVER=log
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
AT_USSD_SERVICE_CODE="*384*1234#"
# Shared secret to authenticate AT's POST callback (optional until AT confirms mechanism).
AT_CALLBACK_SECRET=

# --- Visitor data retention (Uganda DPA — configurable, not "forever") ---
VISIT_RETENTION_DAYS=180

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
